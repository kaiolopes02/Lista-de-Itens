{
  "rules": {
    "listas": {
      "$salaId": {
        ".read": true,
        ".write": true,
        "itens": {
          "$idx": {
            "id": {
              ".validate": "newData.isNumber()"
            },
            "nome": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 120"
            },
            "preco": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "quantidade": {
              ".validate": "newData.isNumber() && newData.val() > 0"
            },
            "unidade": {
              ".validate": "newData.isString() && (newData.val() === 'un' || newData.val() === 'kg')"
            },
            "incluido": {
              ".validate": "newData.isBoolean()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "temaAtual": {
          ".validate": "newData.isString() && newData.val().length <= 32"
        },
        "ts": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
